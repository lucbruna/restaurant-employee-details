# Public app URL used for auth callbacks and absolute metadata.
APP_URL="http://localhost:3000"

# NextAuth session encryption secret.
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional explicit demo-mode bypass for local walkthroughs only.
APP_DEMO_MODE="false"

# Gemini API key used by the server-side AI helper flows in `lib/ai.ts`.
GEMINI_API_KEY="replace-with-your-gemini-api-key"

# Optional server host/port overrides for local or container runtime.
HOSTNAME="0.0.0.0"
PORT="3000"

# Optional comma-separated CORS allowlist for Socket.IO clients.
SOCKET_ALLOWED_ORIGINS="http://localhost:3000"

# Optional default payment provider for local environments.
PAYMENTS_DEFAULT_PROVIDER="manual"

# Optional SQLite database path override for isolated local verification runs.
SQLITE_DB_PATH="./sqlite.db"

# Stripe payment gateway configuration.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Razorpay payment gateway configuration.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
