{
  "name": "restaurant-os",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "customer-web",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "dev:all": "npm run dev & npm run dev:customer",
    "dev:customer": "npm run dev -w customer-web",
    "build": "next build && tsc -p tsconfig.server.json",
    "start": "node dist/server.js",
    "start:render": "node scripts/render-start.js",
    "lint": "eslint .",
    "clean": "next clean",
    "db:reset": "tsx db/reset.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
    "db:setup": "npm run db:reset && npm run db:push && npm run db:seed"
  },
